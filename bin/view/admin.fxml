<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.AdminController"
            prefWidth="500.0" prefHeight="500.0">

    <!-- Top bar -->
    <top>
        <VBox style="-fx-background-color: #f4f4f4; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Admin Panel"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="User Management"
                       style="-fx-text-fill: gray; -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- Center: user list -->
    <center>
        <VBox spacing="10.0">
            <padding><Insets top="16" right="16" bottom="8" left="16"/></padding>
            <Label text="Registered Users" style="-fx-font-weight: bold;"/>
            <ListView fx:id="userListView" VBox.vgrow="ALWAYS"
                      prefHeight="350.0"/>
        </VBox>
    </center>

    <!-- Bottom: action buttons -->
    <bottom>
        <VBox>
            <Separator/>
            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <padding><Insets top="10" right="16" bottom="14" left="16"/></padding>
                <Button text="Create User" onAction="#handleCreateUser"
                        style="-fx-font-size: 13px;">
                    <tooltip><Tooltip text="Create a new user account"/></tooltip>
                </Button>
                <Button text="Delete User" onAction="#handleDeleteUser"
                        style="-fx-font-size: 13px;">
                    <tooltip><Tooltip text="Delete the selected user"/></tooltip>
                </Button>
                <Separator orientation="VERTICAL"/>
                <Button text="Logout" onAction="#handleLogout"
                        style="-fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
