<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.LoginController"
      prefWidth="400.0" prefHeight="300.0">

    <padding>
        <Insets top="40" right="60" bottom="40" left="60"/>
    </padding>

    <Label text="Photos" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

    <Label text="Sign in to continue" style="-fx-text-fill: gray;"/>

    <VBox spacing="6.0" maxWidth="280.0" VBox.vgrow="NEVER">
        <Label text="Username"/>
        <TextField fx:id="usernameField" promptText="Enter username"
                   onAction="#handleLogin"/>
    </VBox>

    <Button text="Log In" onAction="#handleLogin"
            defaultButton="true"
            prefWidth="280.0"
            style="-fx-font-size: 14px;"/>

</VBox>
