<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.AlbumListController"
            prefWidth="620.0" prefHeight="540.0">

    <!-- Top bar -->
    <top>
        <VBox style="-fx-background-color: #f4f4f4; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label text="My Albums"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="Search Photos" onAction="#handleSearch"
                        style="-fx-font-size: 13px;">
                    <tooltip><Tooltip text="Search across all albums"/></tooltip>
                </Button>
                <Button text="Logout" onAction="#handleLogout"
                        style="-fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- Center: album list -->
    <center>
        <VBox spacing="8.0">
            <padding><Insets top="16" right="16" bottom="8" left="16"/></padding>
            <Label text="Double-click an album to open it."
                   style="-fx-text-fill: gray; -fx-font-size: 12px;"/>
            <ListView fx:id="albumListView" VBox.vgrow="ALWAYS"
                      prefHeight="400.0"
                      onMouseClicked="#handleAlbumDoubleClick"/>
        </VBox>
    </center>

    <!-- Bottom: album action buttons -->
    <bottom>
        <VBox>
            <Separator/>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <padding><Insets top="10" right="16" bottom="14" left="16"/></padding>
                <Button text="Create" onAction="#handleCreateAlbum"
                        style="-fx-font-size: 13px;">
                    <tooltip><Tooltip text="Create a new album"/></tooltip>
                </Button>
                <Button text="Rename" onAction="#handleRenameAlbum"
                        style="-fx-font-size: 13px;">
                    <tooltip><Tooltip text="Rename the selected album"/></tooltip>
                </Button>
                <Button text="Delete" onAction="#handleDeleteAlbum"
                        style="-fx-font-size: 13px;">
                    <tooltip><Tooltip text="Delete the selected album"/></tooltip>
                </Button>
                <Button text="Open" onAction="#handleOpenAlbum"
                        defaultButton="true"
                        style="-fx-font-size: 13px;">
                    <tooltip><Tooltip text="Open the selected album"/></tooltip>
                </Button>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
