<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.ColumnConstraints?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.TagController"
            prefWidth="500.0" prefHeight="500.0">

    <!-- Top bar -->
    <top>
        <VBox style="-fx-background-color: #f4f4f4; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Button text="&#8592; Back" onAction="#handleBack"
                        style="-fx-font-size: 13px;"/>
                <Label text="Manage Tags"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16.0">
            <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

            <!-- Add tag section -->
            <Label text="Add a Tag" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

            <GridPane hgap="12.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="40"/>
                    <ColumnConstraints percentWidth="60"/>
                </columnConstraints>

                <Label text="Tag Type" GridPane.columnIndex="0" GridPane.rowIndex="0"
                       style="-fx-font-size: 13px;"/>
                <ComboBox fx:id="tagTypeComboBox"
                          GridPane.columnIndex="1" GridPane.rowIndex="0"
                          maxWidth="Infinity"
                          style="-fx-font-size: 13px;">
                    <tooltip><Tooltip text="Select a type or add a new one"/></tooltip>
                </ComboBox>

                <Label text="Value" GridPane.columnIndex="0" GridPane.rowIndex="1"
                       style="-fx-font-size: 13px;"/>
                <TextField fx:id="tagValueField"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"
                           promptText="e.g. Prague, Susan"
                           onAction="#handleAddTag"
                           style="-fx-font-size: 13px;"/>
            </GridPane>

            <HBox spacing="10.0">
                <Button text="Add Tag" onAction="#handleAddTag"
                        defaultButton="true"
                        style="-fx-font-size: 13px;">
                    <tooltip><Tooltip text="Add this tag to the photo"/></tooltip>
                </Button>
            </HBox>

            <Separator/>

            <!-- Existing tags section -->
            <Label text="Current Tags" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Label text="Select a tag below, then press Delete Tag to remove it."
                   style="-fx-text-fill: gray; -fx-font-size: 12px;"/>

            <ListView fx:id="tagListView" VBox.vgrow="ALWAYS"
                      prefHeight="200.0"
                      style="-fx-font-size: 13px;"/>

            <HBox spacing="10.0">
                <Button text="Delete Tag" onAction="#handleDeleteTag"
                        style="-fx-font-size: 13px;">
                    <tooltip><Tooltip text="Remove the selected tag from this photo"/></tooltip>
                </Button>
            </HBox>

        </VBox>
    </center>

</BorderPane>
