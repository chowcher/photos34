<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.SearchResultsController"
            prefWidth="680.0" prefHeight="580.0">

    <!-- Top bar -->
    <top>
        <VBox style="-fx-background-color: #f4f4f4; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Button text="&#8592; Back" onAction="#handleBack"
                        style="-fx-font-size: 13px;"/>
                <Label text="Search Results"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="resultCountLabel"
                       style="-fx-text-fill: gray; -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- Center: results thumbnail list -->
    <center>
        <VBox spacing="8.0">
            <padding><Insets top="12" right="16" bottom="8" left="16"/></padding>
            <Label text="Photos matching your search criteria:"
                   style="-fx-text-fill: gray; -fx-font-size: 12px;"/>
            <ListView fx:id="resultsListView" VBox.vgrow="ALWAYS"
                      prefHeight="450.0"/>
        </VBox>
    </center>

    <!-- Bottom: save as album -->
    <bottom>
        <VBox>
            <Separator/>
            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <padding><Insets top="10" right="16" bottom="14" left="16"/></padding>
                <Button text="Save as New Album" onAction="#handleSaveAsAlbum"
                        defaultButton="true"
                        style="-fx-font-size: 13px;">
                    <tooltip>
                        <Tooltip text="Save these results as a new album"/>
                    </tooltip>
                </Button>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
