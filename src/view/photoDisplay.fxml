<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.PhotoDisplayController"
            prefWidth="720.0" prefHeight="620.0">

    <!-- Top bar -->
    <top>
        <VBox style="-fx-background-color: #f4f4f4; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Button text="&#8592; Back" onAction="#handleBack"
                        style="-fx-font-size: 13px;"/>
                <Label text="Photo Details"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <!-- Center: image + metadata side by side -->
    <center>
        <HBox spacing="20.0">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

            <!-- Left: image -->
            <ScrollPane fitToWidth="true" fitToHeight="true"
                        HBox.hgrow="ALWAYS"
                        style="-fx-background-color: #1a1a1a; -fx-background: #1a1a1a;">
                <ImageView fx:id="photoImageView"
                           fitWidth="440.0" fitHeight="520.0"
                           preserveRatio="true"
                           smooth="true"/>
            </ScrollPane>

            <!-- Right: metadata panel -->
            <VBox spacing="14.0" prefWidth="220.0" minWidth="200.0">

                <Label text="Caption" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                <Label fx:id="captionLabel"
                       wrapText="true"
                       style="-fx-font-size: 13px; -fx-text-fill: #333;"/>

                <Separator/>

                <Label text="Date Taken" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                <Label fx:id="dateLabel"
                       style="-fx-font-size: 13px; -fx-text-fill: #333;"/>

                <Separator/>

                <Label text="Tags" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                <ListView fx:id="tagListView"
                          VBox.vgrow="ALWAYS"
                          prefHeight="200.0"
                          style="-fx-font-size: 13px;"/>
            </VBox>
        </HBox>
    </center>

</BorderPane>
