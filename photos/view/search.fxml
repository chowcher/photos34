<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="photos.controller.SearchController"
            prefWidth="540.0" prefHeight="520.0">

    <!-- Top bar -->
    <top>
        <VBox style="-fx-background-color: #f4f4f4; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Button text="&#8592; Back" onAction="#handleBack"
                        style="-fx-font-size: 13px;"/>
                <Label text="Search Photos"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16.0">
            <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

            <!-- Mode selection -->
            <Label text="Search by:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <HBox spacing="24.0">
                <RadioButton fx:id="dateRangeRadio" text="Date Range"
                             selected="true">
                    <toggleGroup><ToggleGroup fx:id="searchModeGroup"/></toggleGroup>
                </RadioButton>
                <RadioButton fx:id="tagSearchRadio" text="Tag Values"
                             toggleGroup="$searchModeGroup"/>
            </HBox>

            <Separator/>

            <!-- Date range section -->
            <TitledPane text="Date Range" collapsible="false"
                        style="-fx-font-size: 13px;">
                <GridPane hgap="12.0" vgap="10.0">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <columnConstraints>
                        <ColumnConstraints percentWidth="35"/>
                        <ColumnConstraints percentWidth="65"/>
                    </columnConstraints>

                    <Label text="Start Date" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <DatePicker fx:id="startDatePicker"
                                GridPane.columnIndex="1" GridPane.rowIndex="0"
                                maxWidth="Infinity"
                                promptText="Pick start date"/>

                    <Label text="End Date" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <DatePicker fx:id="endDatePicker"
                                GridPane.columnIndex="1" GridPane.rowIndex="1"
                                maxWidth="Infinity"
                                promptText="Pick end date"/>
                </GridPane>
            </TitledPane>

            <Separator/>

            <!-- Tag search section -->
            <TitledPane text="Tag Search" collapsible="false"
                        style="-fx-font-size: 13px;">
                <VBox spacing="10.0">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                    <!-- Tag 1 -->
                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label text="Type:" minWidth="40"/>
                        <ComboBox fx:id="tagType1ComboBox"
                                  prefWidth="140.0"
                                  style="-fx-font-size: 13px;"/>
                        <Label text="=" style="-fx-font-size: 14px;"/>
                        <TextField fx:id="tagValue1Field"
                                   promptText="value"
                                   prefWidth="160.0"
                                   style="-fx-font-size: 13px;"/>
                    </HBox>

                    <!-- Conjunction -->
                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label text="Combine:" minWidth="60"/>
                        <ComboBox fx:id="conjunctionComboBox"
                                  promptText="(optional)"
                                  prefWidth="100.0"
                                  style="-fx-font-size: 13px;">
                            <tooltip>
                                <Tooltip text="Leave blank for single-tag search"/>
                            </tooltip>
                        </ComboBox>
                    </HBox>

                    <!-- Tag 2 -->
                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label text="Type:" minWidth="40"/>
                        <ComboBox fx:id="tagType2ComboBox"
                                  prefWidth="140.0"
                                  style="-fx-font-size: 13px;"/>
                        <Label text="=" style="-fx-font-size: 14px;"/>
                        <TextField fx:id="tagValue2Field"
                                   promptText="value (optional)"
                                   prefWidth="160.0"
                                   style="-fx-font-size: 13px;"/>
                    </HBox>
                </VBox>
            </TitledPane>

        </VBox>
    </center>

    <!-- Bottom: search button -->
    <bottom>
        <VBox>
            <Separator/>
            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <padding><Insets top="10" right="16" bottom="14" left="16"/></padding>
                <Button text="Search" onAction="#handleSearch"
                        defaultButton="true"
                        style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
