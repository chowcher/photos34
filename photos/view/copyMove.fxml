<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="photos.controller.CopyMoveController"
            prefWidth="420.0" prefHeight="420.0">

    <!-- Top bar -->
    <top>
        <VBox style="-fx-background-color: #f4f4f4; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Button text="&#8592; Cancel" onAction="#handleCancel"
                        style="-fx-font-size: 13px;"/>
                <Label fx:id="titleLabel" text="Copy photo to..."
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <!-- Center: album list -->
    <center>
        <VBox spacing="10.0">
            <padding><Insets top="16" right="16" bottom="8" left="16"/></padding>
            <Label text="Select a destination album:"
                   style="-fx-font-size: 13px;"/>
            <ListView fx:id="albumListView" VBox.vgrow="ALWAYS"
                      prefHeight="300.0"
                      style="-fx-font-size: 13px;"/>
        </VBox>
    </center>

    <!-- Bottom: confirm -->
    <bottom>
        <VBox>
            <Separator/>
            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <padding><Insets top="10" right="16" bottom="14" left="16"/></padding>
                <Button text="Cancel" onAction="#handleCancel"
                        style="-fx-font-size: 13px;"/>
                <Button text="Confirm" onAction="#handleConfirm"
                        defaultButton="true"
                        style="-fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
